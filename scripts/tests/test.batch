#!/usr/bin/env zsh
#SBATCH --job-name=${ATH_JOB_NAME}
#SBATCH --nodes=${ATH_JOB_NODE_COUNT}
#SBATCH --nodelist=${ATH_JOB_NODE_LIST}
#SBATCH --time=${ATH_JOB_TIME}

# Test Test Launch Script

# --nodes=${ATH_JOB_NODE_COUNT}
echo "NAME: Test Launch Script"
echo "JOB: ${ATH_JOB_NAME}"
echo "NODE_LIST: ${ATH_JOB_NODE_LIST}"
echo "BACKEND: ${ATH_BACKEND_PLATFORM}"
echo "BACKEND_NODES: ${ATH_BACKEND_NODES}"
echo "TEST_NODES: ${ATH_TEST_NODES}"
echo "TIMEOUT: ${ATH_JOB_TIME}"
echo "PARTITION?: ${SBATCH_PARTITION}"

# Backend Launch
# $AURORA_SCRIPT_DIR/backend/launch_${ATH_BACKEND_PLATFORM}.sh ${ATH_BACKEND_NODES}

source $AURORA_CLUSTER_DIR/env.sh "aarch64"
srun --nodelist="${ATH_BACKEND_NODES}" "$AURORA_TOPLEVEL/build/server/aurora_remote_engine"

# time to bind
sleep 1

# Setup Host Launch
source $AURORA_CLUSTER_DIR/env.sh "x86_64"

srun --nodelist="${ATH_TEST_NODES}" "$AURORA_TOPLEVEL/build/server/aurora_remote_engine"



echo "[$(date)] BENCHMARK RUN FINISHED"

