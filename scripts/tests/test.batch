#!/usr/bin/env zsh
#SBATCH --job-name=${ATH_JOB_NAME}
#SBATCH --nodes=${ATH_JOB_NODE_COUNT}
#SBATCH --nodelist=${ATH_JOB_NODE_LIST}
#SBATCH --time=${ATH_JOB_TIME}

# Test Test Launch Script

echo "NAME: Test Launch Script"
echo "JOB: ${ATH_JOB_NAME}"
echo "NODE_LIST: ${ATH_JOB_NODE_LIST}"
echo "BACKEND: ${ATH_BACKEND_PLATFORM}"
echo "BACKEND_NODES: ${ATH_BACKEND_NODES}"
echo "TEST_NODES: ${ATH_TEST_NODES}"
echo "TIMEOUT: ${ATH_JOB_TIME}"

# Backend Launch
if [[ $ATH_BACKEND_PLATFORM == "bf" ]]; then
    echo "Launching BF:"
    for NODE in $ATH_BACKEND_NODES; do
        echo "->$NODE"
    done
elif [[ $ATH_BACKEND_PLATFORM == "none" ]]; then
    echo "Not Launching Backend"
elif [[ $ATH_BACKEND_PLATFORM == "node" ]]; then
    echo "Launching backend on ${ATH_BACKEND_NODES[*]}"
else
    echo "Not Launching Backend"
fi

# time to bind
# sleep 5

# Setup Host Launch
# source setup_env.sh "x86_64" $PROFILE




echo "[$(date)] BENCHMARK RUN FINISHED"

