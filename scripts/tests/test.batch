#!/usr/bin/env zsh

#--job-name=${ATH_JOB_NAME}
#--nodes=${ATH_JOB_NODE_COUNT}
#--nodelist=${ATH_JOB_NODE_LIST}
#--time=${ATH_JOB_TIME}

# Test Test Launch Script

# --nodes=${ATH_JOB_NODE_COUNT}
echo "NAME: Test Launch Script"
echo "JOB: ${ATH_JOB_NAME}"
echo "NODE_LIST: ${ATH_JOB_NODE_LIST}"
echo "BACKEND: ${ATH_BACKEND_PLATFORM}"
echo "BACKEND_NODES: ${ATH_BACKEND_NODES}"
echo "TEST_NODES: ${ATH_TEST_NODES}"
echo "TIMEOUT: ${ATH_JOB_TIME}"
echo "PARTITION?: ${SBATCH_PARTITION}"

# Backend Launch
source $AURORA_CLUSTER_DIR/env.sh "aarch64"

srun --label \
    --nodelist="${ATH_BACKEND_NODES}" \
    --job-name="ARE_${ATH_JOB_NAME}" \
    "$AURORA_TOPLEVEL/build_BF/server/aurora_remote_engine" &
BACKEND_PID=$!

# time to bind
sleep 1

# Host Launch
source $AURORA_CLUSTER_DIR/env.sh "x86_64"

srun --label \
    --nodelist="${ATH_TEST_NODES}" \
    --job-name="test_discovery" \
    "$AURORA_TOPLEVEL/build/tests/test_discovery"

# Shutdown the server
scancel --name="ARE_${ATH_JOB_NAME}" \
    --signal=TERM \
    --user=$USER

sleep 2

echo "[$(date)] BENCHMARK RUN FINISHED"

